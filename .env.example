# Circle production environment
NODE_ENV=production
PORT=8787
BIND_HOST=127.0.0.1

# Comma-separated origins (required in strict/production)
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173

# Fail-closed production bar
NYXPAY_STRICT=1
NYXPAY_REQUIRE_PROOFS=1
# Default ON in strict (unless NYXPAY_REQUIRE_ZK_PROVE=0) — needs proof-server
NYXPAY_REQUIRE_ZK_PROVE=1
# Require Preprod broadcast/anchor on settle (set =0 to skip)
NYXPAY_REQUIRE_ONCHAIN=1

# Merchant signing: software (SoftHSM) | external (live appliance)
# NYXPAY_MERCHANT_SIGNING=external
# MERCHANT_HSM_URL=http://127.0.0.1:9090
# MERCHANT_HSM_TOKEN=
# MERCHANT_HSM_MASTER_KEY=

# AES-256-GCM key for sealing merchant HMAC secrets (64 hex chars)
MERCHANT_KEK=

# Compact localSecretKey witness (64 hex chars) — never commit
COMPACT_LOCAL_SK=

# Agent skill API bearer token (required in production NODE_ENV=production)
API_SKILL_TOKEN=

# Persistence
NYXPAY_STORE_PATH=/var/lib/circled/circled-store.db

# Midnight
MIDNIGHT_PROOF_SERVER_URL=http://127.0.0.1:6300
# MIDNIGHT_WALLET_SEED=
# MIDNIGHT_CONTRACT_ADDRESS=

# Optional multi-instance rate limits
# REDIS_URL=redis://127.0.0.1:6379

# Dev / soft-demo escape hatches (never in real prod)
# NYXPAY_ALLOW_EPHEMERAL_KEK=1
# NYXPAY_BOOT_SOFT=1
# NYXPAY_ALLOW_DEMO_SEED=1
# NYXPAY_ALLOW_STUB_RAILS=1
# NYXPAY_REQUIRE_ZK_PROVE=0
# NYXPAY_REQUIRE_ONCHAIN=0
