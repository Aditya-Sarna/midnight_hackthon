{
  "name": "circled",
  "private": true,
  "version": "5.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "npm run build && NODE_ENV=production NYXPAY_STRICT=1 tsx server/index.ts",
    "start:soft": "npm run build && NODE_ENV=production NYXPAY_BOOT_SOFT=1 NYXPAY_ALLOW_EPHEMERAL_KEK=1 NYXPAY_ALLOW_DEMO_SEED=1 NYXPAY_ALLOW_STUB_RAILS=1 NYXPAY_REQUIRE_ZK_PROVE=0 NYXPAY_REQUIRE_ONCHAIN=0 tsx server/index.ts",
    "start:prod": "npm run build && NODE_ENV=production NYXPAY_STRICT=1 NYXPAY_REQUIRE_ZK_PROVE=1 NYXPAY_REQUIRE_PROOFS=1 tsx server/index.ts",
    "start:server": "NODE_ENV=production NYXPAY_STRICT=1 tsx server/index.ts",
    "cap:sync": "npm run build && npx cap sync",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "cap:android": "npm run cap:sync && npx cap open android",
    "compact:compile": "COMPACTC_VERSION=0.31.1 npx run-compactc contracts/nyxpay.compact contracts/managed/nyxpay",
    "proof-server": "docker run --rm -p 6300:6300 midnightntwrk/proof-server:8.0.3 -- midnight-proof-server -v",
    "proof-server:up": "docker compose -f docker-compose.proof-server.yml up -d",
    "proof-server:down": "docker compose -f docker-compose.proof-server.yml down",
    "midnight:status": "curl -s http://127.0.0.1:8787/api/midnight | python3 -m json.tool",
    "midnight:deploy": "tsx scripts/midnight-deploy.ts",
    "midnight:new-wallet": "tsx scripts/new-wallet.ts",
    "midnight:balance": "tsx scripts/check-balance.ts",
    "hsm:appliance": "tsx server/hsmAppliance/server.ts"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.1",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/splash-screen": "^8.0.2",
    "@fontsource/outfit": "^5.2.8",
    "@fontsource/syne": "^5.2.7",
    "@midnight-ntwrk/compact-js": "^2.5.1",
    "@midnight-ntwrk/compact-runtime": "^0.16.0",
    "@midnight-ntwrk/ledger-v8": "^8.1.0",
    "@midnight-ntwrk/midnight-js-compact": "^4.1.1",
    "@midnight-ntwrk/midnight-js-contracts": "^4.1.1",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "^4.1.1",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "^4.1.1",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "^4.1.1",
    "@midnight-ntwrk/midnight-js-network-id": "^4.1.1",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "^4.1.1",
    "@midnight-ntwrk/midnight-js-types": "^4.1.1",
    "@midnight-ntwrk/midnight-js-utils": "^4.1.1",
    "@midnight-ntwrk/testkit-js": "^4.1.1",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "^4.1.0",
    "@midnight-ntwrk/wallet-sdk-facade": "^4.0.1",
    "@midnight-ntwrk/wallet-sdk-hd": "^3.0.3",
    "@midnight-ntwrk/wallet-sdk-shielded": "^3.0.1",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "^3.1.0",
    "@midnightntwrk/wallet-sdk": "^1.2.0",
    "better-sqlite3": "^12.11.1",
    "buffer": "^6.0.3",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "redis": "^4.7.1",
    "rxjs": "^7.8.2",
    "uuid": "^11.1.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/helmet": "^0.0.48",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "~5.8.3",
    "vite": "^6.3.3",
    "vitest": "^2.1.9"
  }
}
